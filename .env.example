# Environment Variables Template for E-commerce Microservices
# Copy this file to .env and update with your values

# ======================
# DATABASE CONFIGURATION
# ======================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# Multiple databases (each service has its own DB)
# - auth_db (Auth Service)
# - product_db (Product Service)
# - order_db (Order Service)
# - inventory_db (Inventory Service)
# - payment_db (Payment Service)
# - gateway_db (API Gateway)

# ======================
# REDIS CONFIGURATION
# ======================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ======================
# RABBITMQ CONFIGURATION
# ======================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MGMT_PORT=15672

# ======================
# JWT CONFIGURATION (Auth Service)
# ======================
JWT_SECRET=your_jwt_secret_key_change_this
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ======================
# MONGODB CONFIGURATION (Auth Service)
# ======================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=

# ======================
# SERVICE PORTS
# ======================
GATEWAY_PORT=8080
DEBUG_PORT=5005
AUTH_PORT=3001
PRODUCT_PORT=3002
ORDER_PORT=3003
PAYMENT_PORT=3004
INVENTORY_PORT=3005
NOTIFICATION_PORT=3006

# ======================
# NODE ENVIRONMENT
# ======================
NODE_ENV=development

# ======================
# EMAIL CONFIGURATION (Notification Service)
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@ecommerce.com

# ======================
# PAYMENT GATEWAY (Payment Service)
# ======================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ======================
# STORAGE (Product Service)
# ======================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ======================
# LOGGING
# ======================
LOG_LEVEL=debug

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ======================
# CORS
# ======================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
